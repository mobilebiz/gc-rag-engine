# Google Cloud Project Configuration
# PROJECT_ID: Project ID string (e.g. "my-project-v2") - Used for general reference
PROJECT_ID=your-project-id-string
# PROJECT_NUMBER: Numeric Project Number (e.g. 123456789012) - Required for v1alpha API
PROJECT_NUMBER=your-numeric-project-id
LOCATION=global
# Discovery Engine (Vertex AI Agent Builder) ID
AI_APPLICATION_ID=your-engine-id

# Gemini API Key for data optimization (Get from Google AI Studio)
API_KEY=your-gemini-api-key

# Optional: GCS Bucket URI for reference
BUCKET_URI=gs://your-bucket-name/path/to/doc.txt
